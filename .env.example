# ---------- Supabase (Phase 1+) ----------
# From Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# From Supabase project settings > Database (connection pooling, Session mode)
# Used by Drizzle for migrations + server-side queries
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ---------- Admin access (Phase 1 fallback; replaced by Supabase Auth magic link in Phase 2) ----------
DASHBOARD_PASSWORD=change-me
# Comma separated emails allowed to login via magic link (Phase 2)
ADMIN_EMAIL_ALLOWLIST=you@example.com

# ---------- Wallet module (Phase 4) ----------
# 32 bytes random, generate with: openssl rand -hex 32
ENCRYPTION_PEPPER=

# RPC providers (Phase 4)
ALCHEMY_API_KEY=
NEXT_PUBLIC_ALCHEMY_ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ALCHEMY_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ALCHEMY_ARB_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ALCHEMY_OP_RPC=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ALCHEMY_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

HELIUS_API_KEY=
NEXT_PUBLIC_HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# WalletConnect Cloud project id
NEXT_PUBLIC_WC_PROJECT_ID=

# ---------- Delayed job queue (Phase 4 gas distributor) ----------
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ---------- App ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
